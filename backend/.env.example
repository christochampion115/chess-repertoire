# Local environment variables for Alpha Chess backend
# Copy this file to .env and fill in the values.

# Optional Lichess explorer proxy host (defaults to https://explorer.lichess.ovh)
LICHESS_EXPLORER_HOST=https://explorer.lichess.org

# Optional token for Lichess explorer proxy if anonymous access is denied
LICHESS_EXPLORER_TOKEN=

# JWT secret for auth tokens — OBLIGATOIRE en production (clé longue et aléatoire)
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=alpha-chess-secret-change-me

# CORS — restreindre à votre domaine en production
# Ex: CORS_ORIGIN=https://votre-domaine.com
# Laisser vide = '*' (tout accepté, déconseillé en production)
CORS_ORIGIN=

# Port du serveur (défaut : 4000)
PORT=4000

# NODE_ENV — mettre 'production' sur le serveur (active les vérifications de sécurité)
NODE_ENV=development
